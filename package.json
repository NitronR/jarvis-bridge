{
  "name": "jarvis-bridge",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["frontend"],
  "main": "dist/index.js",
  "bin": {
    "jarvis-bridge": "./bin/jarvis-bridge.js"
  },
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "TS_NODE_TRANSPILE_ONLY=true node -r ts-node/register --test 'src/**/*.test.ts' 'scripts/**/*.test.js'",
    "setup": "node scripts/setup.js",
    "postinstall": "echo \"[trace] postinstall shell reached $(date), pid=$$, cwd=$(pwd)\" >> /tmp/jarvis-bridge-setup-trace.log; echo \"[trace] which node: $(which node 2>&1), version: $(node --version 2>&1)\" >> /tmp/jarvis-bridge-setup-trace.log; node scripts/setup.js; echo \"[trace] node scripts/setup.js exited with code $?\" >> /tmp/jarvis-bridge-setup-trace.log; npm run build:web",
    "dev:web": "cd frontend && npm run dev",
    "build:web": "cd frontend && npm run build",
    "preview:web": "cd frontend && npm run preview",
    "test:web": "cd frontend && npm test -- --run"
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.12.0",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "jpeg-js": "^0.4.4",
    "pngjs": "^7.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^4.17.21",
    "@types/jpeg-js": "^0.3.0",
    "@types/node": "^22.7.0",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^25.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0",
    "vite": "^5.4.21",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=22"
  }
}
