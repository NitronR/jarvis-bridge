# Jarvis Bridge — Environment Configuration
#
# Copy to .env and fill in. Lines beginning with # are comments.
# All names below are documented; defaults shown are what the gateway uses
# when the variable is unset (or set to anything other than the listed opt-in).

# ── Core ──────────────────────────────────────────────────────────────────
# Workspace root (created if missing). The agent's default cwd.
JARVIS_BRIDGE_WORKSPACE=~/.jarvis-bridge

# System dir for gateway-managed config/state (agents.json, settings.json, etc).
# Default shown; uncomment to relocate it.
# JARVIS_BRIDGE_SYSTEM_DIR=~/.jarvis-bridge-system

# Gateway HTTP port.
PORT=3001

# ── Agent subprocess ─────────────────────────────────────────────────────
# Backend selection lives in agents.json. `scripts/setup.js` scaffolds one
# automatically at <JARVIS_BRIDGE_SYSTEM_DIR>/config/agents.json (default:
# ~/.jarvis-bridge-system/config/agents.json) — no action needed for the
# common case. Only set JARVIS_BRIDGE_AGENTS_CONFIG if you want agents.json to
# live somewhere else (e.g. a repo-relative copy during local dev); leaving it
# unset is recommended so the scaffolded system-dir copy is used.
# JARVIS_BRIDGE_AGENTS_CONFIG=./agents.json
JARVIS_BRIDGE_DEFAULT_BACKEND=opencode

# Backend-wide default for the Auto-approve toggle.
# Opt-in: only the literal string "true" enables; anything else is false.
AGENT_AUTO_APPROVE=false

# ── Terminal drawer ──────────────────────────────────────────────────────
# Set false to disable the WebSocket terminal drawer entirely.
JARVIS_BRIDGE_SHELL=true

# ── Optional integrations ────────────────────────────────────────────────
# Slack bot token (xoxb-...) for POST /slack/message.
SLACK_BOT_TOKEN=

# Gateway URL used by the optional stdio MCP server (P6).
JARVIS_BRIDGE_GATEWAY_URL=http://localhost:3001

# Path to a file where gateway logs are appended (in addition to the terminal).
# Default: <JARVIS_BRIDGE_SYSTEM_DIR>/logs/gateway.log. Set to empty to disable
# file logging entirely.
# JARVIS_BRIDGE_LOG_FILE=