# Dependencies
node_modules/

# Build output
dist/
build/
# Frontend build output — 100% generated by `npm run build:web`
# (vite.config.ts outDir: "../public", emptyOutDir: true). Never hand-edited;
# regenerated automatically via postinstall, or manually via build:web.
/public/

# Environment & secrets
.env
.env.local
.env.*.local

# Backend config (machine-specific commands/env) & runtime settings
agents.json

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime workspace (agent working dir, generated at runtime)
workspace/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# TypeScript
*.tsbuildinfo

.superpowers/
# Git worktrees
.worktrees/
